---
import Pagination from '../../components/Pagination.astro';
import PostHeader from '../../components/PostHeader.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getBlogPosts, type LegacyEntry } from '../../lib/legacy-content';

export function getStaticPaths() {
  const posts = getBlogPosts();

  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      newer: posts[index - 1] ?? null,
      older: posts[index + 1] ?? null
    }
  }));
}

interface Props {
  post: LegacyEntry;
  newer?: LegacyEntry | null;
  older?: LegacyEntry | null;
}

const { post, newer = null, older = null } = Astro.props;
---

<BaseLayout title={post.title} description={post.description} canonicalUrl={post.canonicalUrl}>
  <article class="reading-column reading-column--post">
    <PostHeader post={post} linked={false} />
    <div class="markdown" set:html={post.contentHtml} />
  </article>
  <Pagination newer={newer} older={older} />
</BaseLayout>